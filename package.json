{
  "name": "marine-licensing-journey-tests",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "engines": {
    "node": ">=22.21.0",
    "npm": ">=10.0.0"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "scripts": {
    "clean": "rm -rf allure-results && rm -rf allure-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "git:pre-commit-hook": "npm run format && npm run lint && npm run lint:gherkin && npm run lint:steps",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:gherkin": "node bin/gherkin-standards-validation/index.js",
    "lint:steps": "node bin/steps-analyzer/index.js",
    "postinstall": "npm run setup:husky",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "report": "allure generate allure-results --clean",
    "report:github": "allure generate allure-results --clean --single-file --output allure-report",
    "report:publish": "npm run report:pw; ./bin/publish-tests.sh",
    "knip": "knip",
    "test": "cucumber-js --config cucumber.pw.mjs --format summary",
    "test:smoke": "cucumber-js --config cucumber.pw.mjs --profile smoke --format summary",
    "test:pw": "cucumber-js --config cucumber.pw.mjs --format summary",
    "test:pw:smoke": "cucumber-js --config cucumber.pw.mjs --profile smoke --format summary",
    "test:pw:github": "cucumber-js --config cucumber.pw.mjs --profile github",
    "test:pw:cdp": "cucumber-js --config cucumber.pw.mjs --profile cdp",
    "clean:pw": "rm -rf allure-results && rm -rf allure-report",
    "report:pw": "allure generate allure-results --clean --single-file --output allure-report",
    "report:pw:open": "allure generate allure-results --clean && allure open allure-report"
  },
  "dependencies": {
    "allure-commandline": "2.34.1",
    "date-fns": "4.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.6.0",
    "@faker-js/faker": "9.7.0",
    "@playwright/test": "1.55.1",
    "@types/node": "24.1.0",
    "allure-cucumberjs": "3.4.5",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "glob": "12.0.0",
    "husky": "9.1.7",
    "knip": "5.62.0",
    "neostandard": "0.12.1",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "uuid": "11.1.0"
  },
  "overrides": {
    "@cucumber/cucumber": {
      "glob": "11.1.0"
    }
  }
}
